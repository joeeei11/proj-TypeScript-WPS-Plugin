{
  "name": "wps-typesetter-plugin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "addonType": "wps",
  "scripts": {
    "dev": "concurrently \"npm run dev:service\" \"npm run dev:panel\"",
    "dev:panel": "vite",
    "dev:service": "tsx watch service/src/index.ts",
    "dev:service:wps": "cross-env PANEL_DEV_SERVER=http://127.0.0.1:5173 tsx watch service/src/index.ts",
    "dev:wps": "npm run build:ribbon && npm run wps:install-debug && concurrently \"npm run dev:panel\" \"npm run dev:service:wps\"",
    "start:service": "node dist/service/service/src/index.js",
    "start:wps": "npm run build && npm run wps:install-debug && npm run wps:launch && npm run start:service",
    "build": "npm run build:panel && npm run build:service && npm run build:ribbon",
    "build:panel": "node scripts/build-panel.mjs",
    "build:service": "tsc -p tsconfig.service.json",
    "build:ribbon": "node scripts/build-ribbon.mjs && node scripts/copy-plugin.mjs",
    "wps:install-debug": "node scripts/register-wps-debug.mjs",
    "wps:remove-debug": "node scripts/register-wps-debug.mjs --remove",
    "wps:doctor": "node scripts/wps-doctor.mjs",
    "wps:launch": "node scripts/launch-wps.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.service.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/multipart": "^9.2.1",
    "@fastify/static": "^8.3.0",
    "fastify": "^5.6.1",
    "mammoth": "^1.10.0",
    "openai": "^5.23.0",
    "pdf-parse": "^1.1.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "esbuild": "^0.25.11",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vitest": "^3.2.4",
    "wps-jsapi-declare": "^2.2.0",
    "wpsjs": "^2.2.3"
  }
}
